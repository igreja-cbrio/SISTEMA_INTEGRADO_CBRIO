{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && cd backend && npm install",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/{server.js,package.json,routes/**,middleware/**,utils/**,services/**,config/**,agents/**,templates/**,adm_tasks_template.json}",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cerebro/processar",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cerebro/sync-erp",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/kpis/youtube/sync",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/governanca/cron/lembrete",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/kpis/cultos/auto-create",
      "schedule": "5 3 * * 0"
    },
    {
      "path": "/api/processos/cron/coletar",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/|assets/|_vercel/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
